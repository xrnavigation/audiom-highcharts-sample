# Copy to `.env.local` and fill in.

# Audiom API key for the embed (request one from Audiom).
VITE_AUDIOM_API_KEY=

# Used by .npmrc to install @xrnavigation/* from GitHub Packages.
# Create a Personal Access Token (classic) with `read:packages` scope at
# https://github.com/settings/tokens and export it before `npm install`:
#   $env:NPM_TOKEN = "ghp_xxx"   # PowerShell
#   export NPM_TOKEN=ghp_xxx     # bash
NPM_TOKEN=
